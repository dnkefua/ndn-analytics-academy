{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["node", "vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/App.tsx",
    "src/main.tsx",
    "src/types/**/*",
    "src/data.ts",
    "src/components/Header.tsx",
    "src/components/AcademyDashboard.tsx",
    "src/components/AcademyCatalog.tsx",
    "src/components/LessonView.tsx",
    "src/components/AssessmentEngine.tsx",
    "src/components/TranscriptView.tsx",
    "src/components/CertificationsView.tsx",
    "src/components/ProjectPortfolio.tsx",
    "src/components/AiMentorChat.tsx",
    "src/components/BottomNav.tsx",
    "src/components/SidebarDrawer.tsx"
  ]
}
