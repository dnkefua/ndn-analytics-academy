{
  "name": "ndn-analytics-academy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --external:express --external:cors --external:dotenv --external:vite --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc -p tsconfig.app.json --noEmit",
    "optimize:images": "node scripts/optimize-images.cjs",
    "generate:critical": "node scripts/generate-critical.cjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy": "npm run build:ssr && firebase deploy --only hosting,functions",
    "deploy:hosting": "npm run build:ssr && firebase deploy --only hosting",
    "deploy:functions": "npm run build:ssr && firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes,storage",
    "android:add": "cap add android",
    "android:sync": "cap sync android",
    "android:icons": "python scripts/generate_android_icons.py",
    "android:bundle": "npm run android:sync && cd android && gradlew.bat bundleRelease"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/syne": "^5.2.7",
    "@sentry/react": "^10.48.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "esbuild": "^0.25.0",
    "express": "^5.2.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.3.2",
    "three": "^0.184.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.2",
    "critical": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "29.0.1",
    "playwright": "^1.59.1",
    "sharp": "^0.32.4",
    "typescript-eslint": "^8.57.0",
    "vitest": "4.1.2",
    "vitest-axe": "^0.1.0"
  }
}
